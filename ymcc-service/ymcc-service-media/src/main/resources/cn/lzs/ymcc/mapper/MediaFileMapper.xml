<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lzs.ymcc.mapper.MediaFileMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cn.lzs.ymcc.domain.MediaFile">
        <id column="id" property="id" />
        <result column="file_id" property="fileId" />
        <result column="file_name" property="fileName" />
        <result column="file_original_name" property="fileOriginalName" />
        <result column="file_url" property="fileUrl" />
        <result column="file_path" property="filePath" />
        <result column="file_type" property="fileType" />
        <result column="file_status" property="fileStatus" />
        <result column="file_size" property="fileSize" />
        <result column="mime_type" property="mimeType" />
        <result column="upload_time" property="uploadTime" />
        <result column="chapter_id" property="chapterId" />
        <result column="course_id" property="courseId" />
        <result column="number" property="number" />
        <result column="name" property="name" />
        <result column="course_name" property="courseName" />
        <result column="chapter_name" property="chapterName" />
        <result column="time_minute" property="timeMinute" />
        <result column="free" property="free" />
    </resultMap>
    <select id="getMediaFilesByIds" resultType="cn.lzs.ymcc.domain.MediaFile" parameterType="java.lang.String">
        select
        id,
        file_id,
        file_name,
        file_original_name,
        file_url,
        file_path,
        file_type,
        file_status,
        file_size,
        mime_type,
        upload_time,
        chapter_id,
        course_id,
        number,
        name,
        course_name,
        chapter_name,
        time_minute,
        free
        from t_media_file
        where id in
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>
    <select id="getMediaFilesByCourseId" resultType="cn.lzs.ymcc.domain.MediaFile"
            parameterType="java.lang.Long">
        select
            id,
            file_id,
            file_name,
            file_original_name,
            file_url,
            file_path,
            file_type,
            file_status,
            file_size,
            mime_type,
            upload_time,
            chapter_id,
            course_id as courseId,
            number,
            name,
            course_name,
            chapter_name,
            time_minute,
            free
        from t_media_file where course_id = #{courseId}
    </select>


</mapper>
