<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lzs.ymcc.mapper.MessageStationMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cn.lzs.ymcc.domain.MessageStation">
        <id column="id" property="id" />
        <result column="title" property="title" />
        <result column="content" property="content" />
        <result column="type" property="type" />
        <result column="send_time" property="sendTime" />
        <result column="isread" property="isread" />
        <result column="user_id" property="userId" />
    </resultMap>

    <!-- 根据用户ID查询消息列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM t_message_station
        WHERE user_id = #{userId}
        ORDER BY send_time DESC
    </select>

    <!-- 标记用户所有消息为已读 -->
    <update id="markAllAsRead">
        UPDATE t_message_station
        SET isread = 1
        WHERE user_id = #{userId} AND isread = 0
    </update>

</mapper>
