<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lzs.ymcc.mapper.CourseOrderMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cn.lzs.ymcc.domain.CourseOrder">
        <id column="id" property="id" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="order_no" property="orderNo" />
        <result column="total_amount" property="totalAmount" />
        <result column="total_count" property="totalCount" />
        <result column="status_order" property="statusOrder" />
        <result column="user_id" property="userId" />
        <result column="title" property="title" />
        <result column="version" property="version" />
        <result column="pay_type" property="payType" />
    </resultMap>
    <update id="updatePayStatusByOrderNo" parameterType="cn.lzs.ymcc.dto.UpdatePayStatusOrderDTO">
        update t_course_order
        <set>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="statusOrder != null">status_order = #{statusOrder},</if>
        </set>
        where order_no = #{orderNo}
    </update>

</mapper>
